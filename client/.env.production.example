# ========================================================================
# CLIENT — PRODUCTION ENVIRONMENT
# ========================================================================
# Vite picks this file up automatically for `npm run build` (production).
# DO NOT use .env (which has localhost defaults) for the prod build.
# Variables MUST start with VITE_ to be exposed to the bundle.
# ========================================================================

# Backend API base URL — must point to the public API host that both
# bharathfundedtrader.com (user app) and admin.bharathfundedtrader.com
# (admin panel) can reach over HTTPS.
VITE_API_URL=https://api.bharathfundedtrader.com
VITE_API_BASE_URL=https://api.bharathfundedtrader.com/api

# Optional: Google OAuth client id (only when sign-in-with-google ships).
# VITE_GOOGLE_CLIENT_ID=

# MetaAPI keys are server-side only — frontend doesn't need them anymore.
# Leaving these unset keeps the bundle smaller and safer.
